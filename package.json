{
	"name": "mikrotik-manager",
	"private": true,
	"version": "0.0.1",
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 6034",
		"build": "vite build",
		"preview": "vite preview --port 6034",
		"prepare": "svelte-kit sync || echo ''",
		"db:init": "node scripts/init-db.mjs",
		"seed:skills": "node scripts/seed-skills.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/pg": "^8.20.0",
		"playwright": "^1.61.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@huggingface/transformers": "^4.2.0",
		"@lottiefiles/dotlottie-web": "^0.78.0",
		"@node-rs/argon2": "^2.0.2",
		"@sveltejs/adapter-node": "^5.5.7",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"overrides": {
		"adm-zip": "^0.6.0",
		"cookie": "^0.7.2"
	}
}
