# --- App ---
# 32-byte hex (64 chars) master key for encrypting router credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# --- PostgreSQL ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mikrotik_manager

# --- 9router (AI provider) ---
# These are per-user, configured in the UI. Values below are only optional fallbacks.
# NOTE: 9router is chat-only (no embeddings). Base URL example: http://127.0.0.1:20128/v1
NINEROUTER_BASE_URL=
NINEROUTER_API_KEY=
